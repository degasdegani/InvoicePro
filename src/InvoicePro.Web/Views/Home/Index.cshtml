@{
    ViewData["Title"] = "Dashboard";
}

@if (User.Identity != null && User.Identity.IsAuthenticated)
{
    <div class="page-header">
        <h1><i class="bi bi-speedometer2"></i> Dashboard</h1>
        <span class="text-muted">Bem-vindo, @User.Identity.Name!</span>
    </div>

    <!-- Cards de Resumo -->
    <div class="row mb-4">
        <div class="col-md-3 mb-3">
            <div class="card card-dashboard primary h-100">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <div class="text-muted small">Clientes</div>
                        <div class="fw-bold fs-3">@ViewBag.TotalClients</div>
                    </div>
                    <i class="bi bi-people text-primary" style="font-size:2.5rem;opacity:0.3"></i>
                </div>
                <div class="card-footer bg-transparent border-0 pt-0">
                    <a asp-controller="Clients" asp-action="Index" class="small text-primary">Ver todos →</a>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card card-dashboard warning h-100">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <div class="text-muted small">Orçamentos</div>
                        <div class="fw-bold fs-3">@ViewBag.TotalBudgets</div>
                    </div>
                    <i class="bi bi-file-text text-warning" style="font-size:2.5rem;opacity:0.3"></i>
                </div>
                <div class="card-footer bg-transparent border-0 pt-0">
                    <a asp-controller="Budgets" asp-action="Index" class="small text-warning">Ver todos →</a>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card card-dashboard danger h-100">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <div class="text-muted small">Faturas Pendentes</div>
                        <div class="fw-bold fs-3">@ViewBag.PendingInvoices</div>
                    </div>
                    <i class="bi bi-receipt-cutoff text-danger" style="font-size:2.5rem;opacity:0.3"></i>
                </div>
                <div class="card-footer bg-transparent border-0 pt-0">
                    <a asp-controller="Invoices" asp-action="Index" class="small text-danger">Ver todas →</a>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card card-dashboard success h-100">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <div class="text-muted small">Total Recebido</div>
                        <div class="fw-bold fs-4">@((ViewBag.TotalReceived as decimal? ?? 0).ToString("C"))</div>
                    </div>
                    <i class="bi bi-cash-coin text-success" style="font-size:2.5rem;opacity:0.3"></i>
                </div>
                <div class="card-footer bg-transparent border-0 pt-0">
                    <span class="small text-muted">A receber: @((ViewBag.TotalReceivable as decimal? ?? 0).ToString("C"))</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Tabelas Recentes -->
    <div class="row">
        <div class="col-md-6 mb-4">
            <div class="card h-100">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span class="fw-semibold"><i class="bi bi-receipt-cutoff"></i> Faturas Recentes</span>
                    <a asp-controller="Invoices" asp-action="Index" class="btn btn-sm btn-outline-primary">Ver todas</a>
                </div>
                <div class="card-body p-0">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th>Número</th>
                                <th>Cliente</th>
                                <th>Total</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var invoice in ViewBag.RecentInvoices)
                            {
                                <tr>
                                    <td><a asp-controller="Invoices" asp-action="Details" asp-route-id="@invoice.Id">@invoice.Number</a></td>
                                    <td>@invoice.ClientName</td>
                                    <td>@invoice.Total.ToString("C")</td>
                                    <td>
                                        @switch ((string)invoice.Status)
                                        {
                                            case "Pending":
                                                <span class="badge bg-warning text-dark">Pendente</span>
                                                break;
                                            case "Paid":
                                                <span class="badge bg-success">Paga</span>
                                                break;
                                            case "Overdue":
                                                <span class="badge bg-danger">Vencida</span>
                                                break;
                                            default:
                                                <span class="badge bg-secondary">@invoice.Status</span>
                                                break;
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-md-6 mb-4">
            <div class="card h-100">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span class="fw-semibold"><i class="bi bi-file-text"></i> Orçamentos Recentes</span>
                    <a asp-controller="Budgets" asp-action="Index" class="btn btn-sm btn-outline-primary">Ver todos</a>
                </div>
                <div class="card-body p-0">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th>Número</th>
                                <th>Cliente</th>
                                <th>Total</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var budget in ViewBag.RecentBudgets)
                            {
                                <tr>
                                    <td><a asp-controller="Budgets" asp-action="Details" asp-route-id="@budget.Id">@budget.Number</a></td>
                                    <td>@budget.ClientName</td>
                                    <td>@budget.Total.ToString("C")</td>
                                    <td>
                                        @switch ((string)budget.Status)
                                        {
                                            case "Draft":
                                                <span class="badge bg-secondary">Rascunho</span>
                                                break;
                                            case "Approved":
                                                <span class="badge bg-success">Aprovado</span>
                                                break;
                                            case "Sent":
                                                <span class="badge bg-info">Enviado</span>
                                                break;
                                            default:
                                                <span class="badge bg-secondary">@budget.Status</span>
                                                break;
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
}
else
{
    <div class="row justify-content-center mt-5">
        <div class="col-md-6 text-center">
            <i class="bi bi-receipt text-primary" style="font-size:5rem;"></i>
            <h1 class="mt-3 fw-bold">InvoicePro</h1>
            <p class="text-muted fs-5">Sistema profissional de orçamentos e faturas</p>
            <div class="d-flex gap-3 justify-content-center mt-4">
                <a asp-controller="Account" asp-action="Login" class="btn btn-primary btn-lg">
                    <i class="bi bi-box-arrow-in-right"></i> Entrar
                </a>
                <a asp-controller="Account" asp-action="Register" class="btn btn-outline-primary btn-lg">
                    <i class="bi bi-person-plus"></i> Criar Conta
                </a>
            </div>
        </div>
    </div>
}